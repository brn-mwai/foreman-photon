# Foreman config
# Your iMessage address (phone or email) — only messages from this handle are processed.
OWNER_HANDLE=+15555551234

# Gemini API key — used to classify texts into projects.
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Where Foreman stores notes, todos, state.
# Defaults to ~/.foreman
FOREMAN_HOME=

# Morning standup time (24h, local). Empty = no autopush.
STANDUP_AT=07:00

# Stale threshold (days) — project flagged if no note/commit in this window.
STALE_DAYS=3
